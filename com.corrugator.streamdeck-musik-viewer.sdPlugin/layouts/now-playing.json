{
	"$schema": "https://schemas.elgato.com/streamdeck/plugins/layout.json",
	"id": "now-playing",
	"items": [
		{
			"key": "icon",
			"type": "pixmap",
			"rect": [0, 0, 200, 100],
			"zOrder": 0
		},
		{
			"key": "dim",
			"type": "text",
			"rect": [0, 0, 200, 100],
			"value": "",
			"background": "0:#000000F0,0.35:#00000060,0.65:#00000060,1:#000000F0",
			"zOrder": 1
		},
		{
			"key": "track",
			"type": "text",
			"rect": [6, 6, 188, 28],
			"font": { "size": 17, "weight": 700 },
