{
	"$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
	"Name": "Stream Deck Musik Viewer",
	"Version": "1.0.0.6",
	"Author": "corrugator",
	"URL": "https://github.com/Corrugator/streamdeck-musik-viewer",
	"Description": "Shows the currently playing Apple Music track on the Stream Deck+ encoder display, with cover art as background and dial control for volume / mute / play-pause.",
	"Category": "Stream Deck Musik Viewer",
	"CategoryIcon": "imgs/plugin/category-icon",
	"Icon": "imgs/plugin/marketplace",
	"CodePath": "bin/plugin.js",
	"SDKVersion": 3,
	"Software": {
		"MinimumVersion": "6.9"
	},
	"OS": [
		{
			"Platform": "mac",
			"MinimumVersion": "11"
		}
	],
	"Nodejs": {
		"Version": "20",
		"Debug": "enabled"
	},
	"UUID": "com.corrugator.streamdeck-musik-viewer",
	"Actions": [
		{
			"Name": "Now Playing",
			"UUID": "com.corrugator.streamdeck-musik-viewer.now-playing",
			"Icon": "imgs/actions/now-playing/action",
			"Tooltip": "Show the current Apple Music track on the Stream Deck+ encoder. Turn dial to change volume, press to mute, touch to play / pause.",
			"Controllers": [
				"Encoder"
			],
			"States": [
				{
					"Image": "imgs/actions/now-playing/key"
				}
			],
			"Encoder": {
				"layout": "layouts/now-playing.json",
				"Icon": "imgs/actions/now-playing/action",
				"TriggerDescription": {
					"Push": "Mute",
					"Rotate": "Volume",
					"Touch": "Play / Pause"
				}
			}
		}
	]
}