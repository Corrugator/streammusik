			"color": "#FFFFFF",
			"zOrder": 4
		},
		{
			"key": "indicator",
			"type": "bar",
			"rect": [6, 93, 188, 5],
			"value": 0,
			"subtype": 4,
			"border_w": 0,
			"bar_bg_c": "#FFFFFF25",
			"bar_fill_c": "#2DD4BF",
			"zOrder": 5
		}
	]
