			"color": "#ffffff",
			"text-overflow": "ellipsis",
			"zOrder": 2
		},
		{
			"key": "artist",
			"type": "text",
			"rect": [6, 36, 188, 24],
			"font": { "size": 15, "weight": 500 },
			"alignment": "center",
			"color": "#ffffff",
			"text-overflow": "ellipsis",
			"zOrder": 3
		},
		{
			"key": "value",
			"type": "text",
			"rect": [6, 78, 188, 14],
			"font": { "size": 11, "weight": 600 },
