{
	"$schema": "https://schemas.elgato.com/streamdeck/plugins/layout.json",
	"id": "now-playing",
	"items": [
		{
			"key": "track",
			"type": "text",
			"rect": [4, 2, 192, 26],
			"font": { "size": 17, "weight": 700 },
			"alignment": "center",
			"color": "#ffffff",
			"text-overflow": "ellipsis"
		},
		{
			"key": "artist",
			"type": "text",
			"rect": [4, 30, 192, 20],
			"font": { "size": 13, "weight": 400 },
			"alignment": "center",
			"color": "#b8b8b8",
			"text-overflow": "ellipsis"
		},
		{
			"key": "icon",
			"type": "pixmap",
			"rect": [4, 52, 44, 44]
		},
		{
			"key": "value",
			"type": "text",
			"rect": [54, 52, 142, 24],
			"font": { "size": 14, "weight": 600 },
			"alignment": "right",
			"color": "#ffffff"
		},
		{
			"key": "indicator",
			"type": "bar",
			"rect": [54, 82, 142, 12],
			"value": 0,
			"subtype": 4,
			"border_w": 1,
			"bar_bg_c": "#3a3a3a",
			"bar_fill_c": "#ffffff",
			"bar_border_c": "#555555"
		}
	]
}
