{
	"name": "streammusik",
	"version": "0.3.1",
	"repository": {
		"type": "git",
		"url": "https://github.com/Corrugator/streammusik.git"
	},
	"bugs": "https://github.com/Corrugator/streammusik/issues",
	"homepage": "https://github.com/Corrugator/streammusik#readme",
	"description": "Stream Deck plugin that shows the currently playing Apple Music track and controls volume via the Stream Deck+ dial.",
	"type": "module",
	"private": true,
	"license": "MIT",
	"author": "corrugator",
	"scripts": {
		"build": "rollup -c",
		"watch": "rollup -c -w --watch.onEnd=\"streamdeck restart com.corrugator.streammusik\"",
		"validate": "streamdeck validate com.corrugator.streammusik.sdPlugin",
		"pack": "streamdeck pack com.corrugator.streammusik.sdPlugin --force",
		"sync": "./scripts/sync-to-github.sh"
	},
	"devDependencies": {
		"@elgato/cli": "^1.7.0",
		"@rollup/plugin-commonjs": "^28.0.2",
		"@rollup/plugin-node-resolve": "^16.0.0",
		"@rollup/plugin-terser": "^0.4.4",
		"@rollup/plugin-typescript": "^12.1.2",
		"@tsconfig/node20": "^20.1.4",
		"@types/node": "^22.13.0",
		"rollup": "^4.32.1",
		"tslib": "^2.8.1",
		"typescript": "^5.7.3"
	},
	"dependencies": {
		"@elgato/streamdeck": "^2.0.1"
	}
}
